<Window x:Class="_1_Hello.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_1_Hello"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="1000"
        MinHeight="450"
        MinWidth="1000"
        FontSize="24">
    <!--CTRL + K + C (comment); CTRL + K + U (uncomment)-->
    <!-- XAML: Extensible Application Markup Language -->
    <!--Tools -> Options -> Text Editor -> XAML -> Spacing -> ... -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0"
                    Width="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Label Content="Név:"
                       Padding="10"/>
                <TextBox x:Name="NameTextBox"
                         BorderBrush="Black"
                         Text="{Binding PersonName}"
                         Width="250"
                         Padding="10"/>
            </StackPanel>
            <Button Width="200"
                    Height="100"
                    Click="Button_Click"
                    Content="Kattints!"
                    Margin="0,20,0,20" />
            <TextBlock x:Name="GreetText"
                       Padding="10"
                       Background="LightGray"
                       Text="Köszöntés helye..." />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Stretch">
                <Button Content="Hozzáadás"
                        Height="50"
                        Padding="5"
                        Margin="10"
                        Click="AddButton_Click" />
                <Button Content="Szerkesztés"
                        Height="50"
                        Padding="5"
                        Margin="10"/>
                <Button Content="Törlés"
                        Height="50"
                        Padding="5"
                        Margin="10"/>
            </StackPanel>
        </StackPanel>
        <ListBox  Grid.Column="1"
                  BorderBrush="Black"
                  Margin="20"
                  x:Name="NamesListBox"
                  ItemsSource="{Binding Names}">
            <!--<ListBoxItem>Sándor</ListBoxItem>
            <ListBoxItem>József</ListBoxItem>
            <ListBoxItem>Benedek</ListBoxItem>-->
        </ListBox>
    </Grid>
</Window>
