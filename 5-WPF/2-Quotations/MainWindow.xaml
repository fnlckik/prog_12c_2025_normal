<Window x:Class="_2_Quotations.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2_Quotations"
        xmlns:tk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        MinHeight="400" MinWidth="700">
    <!-- Nuget Packet Manager (wpf toolkit) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Button Content="Betöltés"
                        Padding="10"/>
                <Button Content="Tárolás"
                        Padding="10"
                        Margin="50,0,0,0"/>
            </StackPanel>
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <Label Content="Idézet:" />
                <ComboBox MinWidth="200" />
            </StackPanel>
            <TextBlock  Grid.Row="2"
                        Background="LightGoldenrodYellow"
                        Margin="50"
                        Visibility="Hidden"/>
        </Grid>
        <Grid Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0"
                         BorderBrush="Black"
                         Margin="20"/>
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Label Content="Költő:"
                           VerticalAlignment="Center"/>
                    <TextBox MinWidth="200"
                             Padding="10"/>
                </StackPanel>
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Label Content="Cím:"
                           VerticalAlignment="Center"/>
                    <TextBox MinWidth="200"
                             Padding="10"/>
                </StackPanel>
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Label Content="Év:"/>
                    <tk:IntegerUpDown MinWidth="100"
                                      Value="1000"
                                      Minimum="1000"
                                      Maximum="2000"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
